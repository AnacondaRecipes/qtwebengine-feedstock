From 85331086f09d1e0f736aa876cb0dac753821b3e0 Mon Sep 17 00:00:00 2001
From: Andrii Osipov <aosipov@anaconda.com>
Date: Fri, 27 Mar 2026 06:26:29 -0700
Subject: [PATCH] debug run.py with mksnapshot

---
 src/3rdparty/chromium/v8/tools/run.py | 7 +++++--
 1 file changed, 5 insertions(+), 2 deletions(-)

diff --git a/src/3rdparty/chromium/v8/tools/run.py b/src/3rdparty/chromium/v8/tools/run.py
index 77b6538d41..ead8722d04 100755
--- a/src/3rdparty/chromium/v8/tools/run.py
+++ b/src/3rdparty/chromium/v8/tools/run.py
@@ -21,8 +21,11 @@ if cmd and cmd[0] == '--redirect-stdout':
   kwargs = dict(stdout=subprocess.PIPE)
   cmd = cmd[2:]
 
-process = subprocess.Popen(cmd, **kwargs)
-stdout, _ = process.communicate()
+process = subprocess.Popen(cmd, stderr=subprocess.PIPE, **kwargs)
+stdout, stderr = process.communicate()
+if stderr:
+  sys.stderr.write(stderr.decode('utf-8', errors='replace'))
+  sys.stderr.flush()
 if stdout_file:
   with stdout_file.open('w') as f:
     f.write(stdout.decode('utf-8'))
-- 
