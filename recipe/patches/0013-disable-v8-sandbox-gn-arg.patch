From af9040fd8beb95070a21531f8a647e1d2296735a Mon Sep 17 00:00:00 2001
From: Andrii Osipov <aosipov@anaconda.com>
Date: Mon, 1 Jan 2024 00:00:00 +0000
Subject: [PATCH] Pass v8_enable_sandbox=false to GN

Qt WebEngine has no CMake cache option for arbitrary GN args; append this
alongside other gnArgArg entries so args.gn includes it for WebEngineCore.

---
 src/core/CMakeLists.txt | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/src/core/CMakeLists.txt b/src/core/CMakeLists.txt
--- a/src/core/CMakeLists.txt
+++ b/src/core/CMakeLists.txt
@@ -615,6 +615,8 @@ foreach(arch ${archs})
                 CONDITION NOT QT_FEATURE_webengine_system_ssl
             )
         endif()
+
+        list(APPEND gnArgArg v8_enable_sandbox=false)
 
         if(MACOS)
             list(APPEND gnArgArg
